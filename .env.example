# ── Server ────────────────────────────────────────────────
PORT=3000

# ── Database (Neon Postgres) ──────────────────────────────
# Get this from the Neon integration in your Vercel project,
# or from the Neon dashboard. Use the *pooled* connection string.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# ── JWT secrets ───────────────────────────────────────────
TOKEN_KEY=your_access_token_secret
REFRESH_TOKEN_KEY=your_refresh_token_secret

# ── Vercel Blob (image storage) ───────────────────────────
# Auto-injected by Vercel after creating a Blob store.
# For local dev, copy the token from the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# ── Optional: seed the first admin user (npm run seed) ────
SEED_ADMIN_USER=admin
SEED_ADMIN_PASS=change_me
